  ["products!product_compositions_component_sku_fkey", "tokoflow_products!tokoflow_product_compositions_component_sku_fkey"],
  ["products!sales_input_sku_fkey", "tokoflow_products!tokoflow_sales_input_sku_fkey"],
  ["product_costs!sales_input_sku_fkey", "tokoflow_product_costs!tokoflow_sales_input_sku_fkey"],
  ["marketplace_fees!sales_input_channel_fkey", "tokoflow_marketplace_fees!tokoflow_sales_input_channel_fkey"],
  ["products!incoming_goods_input_sku_fkey", "tokoflow_products!tokoflow_incoming_goods_input_sku_fkey"],
