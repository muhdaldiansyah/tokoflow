  [".from('marketplace_fees')", ".from('tokoflow_marketplace_fees')"],
  [".from('av_profiles')", ".from('av_profiles')"], // Keep as is
  
  // Foreign key references
  ["product_costs!product_costs_sku_fkey", "tokoflow_product_costs!tokoflow_product_costs_sku_fkey"],
  ["products!product_costs_sku_fkey", "tokoflow_products!tokoflow_product_costs_sku_fkey"],
