# Supabase Configuration
# Tokoflow project ref: yhwjvdwmwboasehznlfv (anon key from vault, never commit a real one)
NEXT_PUBLIC_SUPABASE_URL=https://yhwjvdwmwboasehznlfv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Application Configuration
NEXT_PUBLIC_APP_NAME=Tokoflow
NEXT_PUBLIC_APP_DESCRIPTION=We handle the receipts. Not the recipes.
# Required — used for logout redirect and Billplz return URL.
NEXT_PUBLIC_APP_URL=https://tokoflow.com

# Payment (disabled by default during Early Access — set to "true" only after
# the Midtrans backend at /api/payment/* is built and creds are configured)
NEXT_PUBLIC_PAYMENT_ENABLED=false

# ============================================================================
# Marketplace integration
# ============================================================================
#
# One-time developer registration per platform. You (Tokoflow the product)
# register ONE Custom App / partner app and every merchant OAuths into it.
# Merchants never see these values — they belong to Tokoflow, not to individual
# shops.
#
# Used by the webhook routes and background sync cron to write rows without
# an authenticated user session. Get it from the Supabase dashboard →
# Settings → API → service_role key. Server-side only, never shipped to client.
SUPABASE_SERVICE_ROLE_KEY=
#
# 32-byte AES-GCM key (base64 encoded) used to encrypt access_token /
# refresh_token at rest in tf_marketplace_connections. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this key requires running a re-encryption migration — bump
# encryption_key_version on every connection row during the migration.
MARKETPLACE_ENCRYPTION_KEY=
#
# Shared secret that protects /api/cron/* endpoints from being called by
# anyone other than Vercel Cron. Vercel sets the Authorization header to
# "Bearer $CRON_SECRET" for scheduled invocations.
CRON_SECRET=
#
# ------------------------------------------------------------------
# TikTok Shop Partner Center (covers TikTok Shop ID + Tokopedia storefronts
# post-merger; Tokopedia classic OpenAPI is being terminated — do not build
# a separate Tokopedia integration).
#   Portal: https://partner.tiktokshop.com
#   Docs:   https://partner.tiktokshop.com/docv2
# ------------------------------------------------------------------
TIKTOKSHOP_APP_KEY=
TIKTOKSHOP_APP_SECRET=
# Must be registered in Partner Center and match the Redirect URL field
# on the app. Default pattern: {SITE_URL}/api/marketplace/callback/tiktok-shop
TIKTOKSHOP_REDIRECT_URI=
#
# ------------------------------------------------------------------
# Shopee Open Platform
#   Portal: https://open.shopee.com
#   Docs:   https://open.shopee.com/documents
# ------------------------------------------------------------------
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
# Default pattern: {SITE_URL}/api/marketplace/callback/shopee
SHOPEE_REDIRECT_URI=
# 'live' or 'test'. 'test' uses partner.test-stable.shopeemobile.com (UAT).
SHOPEE_ENVIRONMENT=test
#
# ------------------------------------------------------------------
# Tokopedia (deprecated — Tokopedia Mitra OpenAPI is being terminated and
# Tokopedia storefronts are absorbed into TikTok Shop Partner Center. Do NOT
# add new Tokopedia integration. Kept here only for awareness.)
# ------------------------------------------------------------------
# TOKOPEDIA_CLIENT_ID=
# TOKOPEDIA_CLIENT_SECRET=
# TOKOPEDIA_REDIRECT_URI=

# ============================================================================
# MyInvois (LHDN e-Invoice) — Pro tier
# ============================================================================
# Tokoflow ERP credentials registered in MyInvois portal. Used for the
# default submission path until per-merchant BYO credentials ship.
MYINVOIS_CLIENT_ID=
MYINVOIS_CLIENT_SECRET=
# Optional — defaults to preprod in dev, prod otherwise.
MYINVOIS_BASE_URL=
MYINVOIS_IDENTITY_BASE=
# AES-256-GCM key used to encrypt per-merchant LHDN client secrets stored in
# profiles.myinvois_client_secret_enc. Any string >= 16 chars; rotation
# requires re-encrypting existing rows. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MYINVOIS_SECRET_KEY=

# ============================================================================
# Billplz (payment) — required pre-launch
# ============================================================================
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
BILLPLZ_X_SIGNATURE_KEY=
BILLPLZ_BASE_URL=

# ============================================================================
# AI (OpenRouter / Gemini Flash Lite)
# ============================================================================
OPENROUTER_API_KEY=

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://tokoflow.com

# Google Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Node.js Configuration (Optional - for build optimization)
NODE_OPTIONS=--max-old-space-size=4096
